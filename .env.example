# ─────────────────────────────────────────────
# Sentrix V7 — Environment Variable Template
# Copy to .env and fill in your values.
# NEVER commit .env with real credentials.
# ─────────────────────────────────────────────

# ── Platform Security ──────────────────────────
# Master API key (required if AUTH_ENABLED=true)
SENTRIX_API_KEY=change-me-strong-random-key

# JWT signing secret (required if AUTH_ENABLED=true)
JWT_SECRET_KEY=change-me-32-char-minimum-secret

# Enable/disable authentication enforcement (default: true)
SENTRIX_AUTH_ENABLED=true

# ── AI Integration ─────────────────────────────
# Set one or both — platform uses whichever is available
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Threat Intelligence Connectors ────────────
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
GEOIP_API_KEY=

# Custom JSON feed URL (optional)
CUSTOM_FEED_URL=

# ── SIEM / EDR Connectors ──────────────────────
WAZUH_URL=
WAZUH_API_KEY=
WAZUH_USERNAME=
WAZUH_PASSWORD=
SIEM_WEBHOOK_URL=

# ── Storage ────────────────────────────────────
# Container path for all persistent data (volume mount point)
DATA_DIR=/data

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO

# ── Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
