{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SentrixAlertOutput",
  "type": "object",
  "required": [
    "alert_id",
    "timestamp",
    "rule_id",
    "rule_name",
    "severity",
    "risk_score",
    "affected_host",
    "attack_story",
    "recommendations"
  ],
  "properties": {
    "alert_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "rule_id": { "type": "string" },
    "rule_name": { "type": "string" },
    "severity": { "type": "string" },
    "risk_score": { "type": "integer" },
    "affected_host": { "type": "string" },
    "user": { "type": "string" },
    "attack_story": {
      "type": "object",
      "required": ["summary", "technical_details", "risk_justification", "timeline"],
      "properties": {
        "summary": { "type": "string" },
        "technical_details": { "type": "string" },
        "risk_justification": { "type": "string" },
        "timeline": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "action"]
      }
    }
  }
}
