{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SentrixRuleDefinition",
  "type": "object",
  "required": [
    "rule_id",
    "rule_name",
    "description",
    "category",
    "severity",
    "confidence",
    "base_risk_score",
    "conditions",
    "recommended_actions",
    "mitre_mapping",
    "version"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$"
    },
    "parent_rule_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$"
      }
    },
    "rule_name": { "type": "string" },
    "description": { "type": "string" },
    "category": { "type": "string" },
    "severity": {
      "type": "string",
      "enum": ["informational", "low", "medium", "high", "critical"]
    },
    "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "base_risk_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "conditions": {
      "type": "object",
      "properties": {
        "all": {
          "type": "array",
          "items": { "$ref": "#/definitions/rule_field_condition" }
        },
        "any": {
          "type": "array",
          "items": { "$ref": "#/definitions/rule_field_condition" }
        }
      }
    },
    "thresholds": {
      "type": "object",
      "required": ["count", "time_window_seconds"],
      "properties": {
        "count": { "type": "integer" },
        "time_window_seconds": { "type": "integer" },
        "unique_values_for": { "type": "string" }
      }
    },
    "correlation": {
      "type": "object",
      "properties": {
        "group_by": {
          "type": "array",
          "items": { "type": "string" }
        },
        "time_window_seconds": { "type": "integer" }
      }
    },
    "sequence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "alias", "conditions"],
        "properties": {
          "step": { "type": "integer" },
          "alias": { "type": "string" },
          "conditions": {
            "type": "object",
            "properties": {
              "all": {
                "type": "array",
                "items": { "$ref": "#/definitions/rule_field_condition" }
              },
              "any": {
                "type": "array",
                "items": { "$ref": "#/definitions/rule_field_condition" }
              }
            }
          }
        }
      }
    },
    "response": {
      "type": "object",
      "required": ["actions"],
      "properties": {
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["action_type", "parameters"],
            "properties": {
              "action_type": { "type": "string" },
              "parameters": { "type": "object" },
              "auto_execution": { "type": "boolean" },
              "approval_required": { "type": "boolean" }
            }
          }
        }
      }
    },
    "recommended_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "action"],
        "properties": {
          "step": { "type": "integer" },
          "action": { "type": "string" },
          "automated_playbook_id": { "type": "string" }
        }
      }
    },
    "mitre_mapping": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tactic", "technique_id"],
        "properties": {
          "tactic": { "type": "string" },
          "technique_id": { "type": "string" },
          "technique_name": { "type": "string" }
        }
      }
    },
    "crisis_mode_overrides": {
      "type": "object",
      "properties": {
        "boost_risk_score": { "type": "integer" },
        "escalate_severity": { "type": "string" },
        "bypass_suppression": { "type": "boolean" }
      }
    },
    "version": { "type": "string" },
    "author": { "type": "string" },
    "last_modified": { "type": "string" }
  },
  "definitions": {
    "rule_field_condition": {
      "type": "object",
      "required": ["field", "operator"],
      "properties": {
        "field": { "type": "string" },
        "operator": { "type": "string" },
        "value": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "array", "items": { "type": "string" } }
          ]
        }
      }
    }
  }
}
